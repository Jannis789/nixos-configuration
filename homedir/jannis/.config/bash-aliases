# Schnellere Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

alias ls='ls --color=auto -lah'

alias update='sudo nixos-rebuild switch --flake ~/Dokumente/nixos-configuration#jannis'
alias upgrade='sudo nixos-rebuild switch --flake ~/Dokumente/nixos-configuration#jannis --upgrade-all'
alias clean-nix='nix-collect-garbage -d'